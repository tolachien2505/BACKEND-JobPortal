@model List<JobPortal.Models.Entities.Job>

@{
    ViewData["Title"] = "Quản lý việc làm";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-1 fw-bold text-gray-900">Quản lý việc làm</h3>
        <div class="text-muted small">Bạn đang có <strong>@Model.Count</strong> tin tuyển dụng trên hệ thống.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="emp-btn emp-btn-secondary" asp-area="Employer" asp-controller="Company" asp-action="Edit">
            <i class="fas fa-building me-2"></i>Hồ sơ công ty
        </a>
        <a class="emp-btn emp-btn-primary" asp-area="Employer" asp-controller="Jobs" asp-action="Create">
            <i class="fas fa-plus me-2"></i>Đăng tin mới
        </a>
    </div>
</div>

<div class="emp-card">
    <div class="emp-card-header">
        <h4 class="emp-card-title">Danh sách tin tuyển dụng</h4>
    </div>
    <div class="p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="text-muted mb-3"><i class="fas fa-box-open fa-3x opacity-50"></i></div>
                <h6 class="fw-semibold">Chưa có tin tuyển dụng nào</h6>
                <p class="text-muted small mb-4">Bắt đầu thu hút nhân tài bằng cách đăng tin tuyển dụng đầu tiên của bạn.</p>
                <a class="emp-btn emp-btn-primary" asp-area="Employer" asp-controller="Jobs" asp-action="Create">Đăng tin ngay</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0 align-middle" style="font-size: 14px;">
                    <thead style="background: #f9fafb; color: #4b5563; font-size: 13px; text-transform: uppercase;">
                        <tr>
                            <th class="ps-4 py-3 font-weight-semibold">Chi tiết tin</th>
                            <th class="py-3 font-weight-semibold">Ứng viên</th>
                            <th class="py-3 font-weight-semibold">Ngày đăng</th>
                            <th class="py-3 font-weight-semibold text-center">Kiểm duyệt</th>
                            <th class="py-3 font-weight-semibold text-center">Trạng thái</th>
                            <th class="pe-4 py-3 text-end font-weight-semibold">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var j in Model.OrderByDescending(x => x.PostedDate))
                        {
                            <tr style="transition: background 0.2s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='white'">
                                <td class="ps-4 py-3">
                                    <div class="fw-semibold text-gray-900 mb-1" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @j.Title
                                    </div>
                                    <div class="text-muted" style="font-size: 12px;">
                                        <i class="fas fa-tag me-1"></i>@j.Category?.Name
                                    </div>
                                </td>
                                <td class="py-3">
                                    <a asp-area="Employer" asp-controller="Applications" asp-action="Index" asp-route-jobId="@j.Id" 
                                       class="badge rounded-pill bg-info text-dark text-decoration-none" style="font-size: 12px; font-weight: 500;">
                                        <i class="fas fa-users me-1"></i> 0 đơn
                                    </a>
                                </td>
                                <td class="py-3 text-muted">@j.PostedDate.ToString("dd/MM/yyyy")</td>
                                <td class="py-3 text-center">
                                    @if (j.ModerationStatus == "Approved")
                                    {
                                        <span class="badge" style="background: #dcfce7; color: #166534;"><i class="fas fa-check-circle me-1"></i>Đã duyệt</span>
                                    }
                                    else if (j.ModerationStatus == "Rejected")
                                    {
                                        <span class="badge" style="background: #fee2e2; color: #991b1b;"><i class="fas fa-times-circle me-1"></i>Từ chối</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background: #fef9c3; color: #854d0e;"><i class="fas fa-clock me-1"></i>Chờ duyệt</span>
                                    }
                                </td>
                                <td class="py-3 text-center">
                                    @if (j.IsActive)
                                    {
                                        <span class="badge" style="background: #e0f2fe; color: #0369a1;">Đang mở</span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background: #f3f4f6; color: #4b5563;">Tạm đóng</span>
                                    }
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="d-flex justify-content-end gap-1">
                                        @if (j.ModerationStatus == "Approved")
                                        {
                                            <a class="btn btn-sm btn-light" style="color: #4b5563;" data-bs-toggle="tooltip" title="Xem trên site" asp-area="" asp-controller="Jobs" asp-action="Details" asp-route-id="@j.Id"><i class="fas fa-external-link-alt"></i></a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-light" style="color: #9ca3af; cursor: not-allowed;" data-bs-toggle="tooltip" title="Tin chưa được duyệt" disabled><i class="fas fa-external-link-alt"></i></button>
                                        }
                                        <a class="btn btn-sm btn-light" style="color: #0284c7;" data-bs-toggle="tooltip" title="Chỉnh sửa" asp-area="Employer" asp-controller="Jobs" asp-action="Edit" asp-route-id="@j.Id"><i class="fas fa-edit"></i></a>
                                        
                                        <form method="post" class="d-inline" asp-area="Employer" asp-controller="Jobs" asp-action="Delete" asp-route-id="@j.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tin tuyển dụng này?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-light text-danger" data-bs-toggle="tooltip" title="Xóa"><i class="fas fa-trash-alt"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Init tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}
