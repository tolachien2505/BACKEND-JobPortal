@model JobPortal.Models.Entities.Job

@{
    ViewData["Title"] = "Đăng tin tuyển dụng";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-1 fw-bold text-gray-900">Đăng tin tuyển dụng</h3>
        <div class="text-muted small">Tin tuyển dụng của bạn sẽ được chuyển sang trạng thái <strong>Chờ duyệt</strong> sau khi tạo.</div>
    </div>
    <a class="emp-btn emp-btn-secondary" asp-area="Employer" asp-controller="Jobs" asp-action="Index">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="emp-card">
    <div class="emp-card-header">
        <h4 class="emp-card-title">Chi tiết công việc</h4>
    </div>
    
    <div class="emp-card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <partial name="_JobForm" model="Model" />

            <div class="mt-4 pt-3 border-top d-flex gap-2 justify-content-end">
                <a class="emp-btn emp-btn-secondary" asp-area="Employer" asp-controller="Jobs" asp-action="Index">Hủy</a>
                <button type="submit" class="emp-btn emp-btn-primary">
                    <i class="fas fa-paper-plane me-2"></i>Tạo tin tuyển dụng
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
