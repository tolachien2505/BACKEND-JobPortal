@model JobPortal.Models.Entities.Job

@{
    ViewData["Title"] = "Sửa tin tuyển dụng";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-1 fw-bold text-gray-900">Chỉnh sửa tin tuyển dụng</h3>
        <div class="text-muted small">Việc chỉnh sửa có thể yêu cầu Admin duyệt lại tùy theo nội dung thay đổi.</div>
    </div>
    <a class="emp-btn emp-btn-secondary" asp-area="Employer" asp-controller="Jobs" asp-action="Index">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="emp-card">
    <div class="emp-card-header">
        <div class="d-flex align-items-center gap-3">
            <h4 class="emp-card-title">Cập nhật nội dung Job #@Model.Id</h4>
            @if (Model.ModerationStatus == "Approved")
            {
                <span class="badge" style="background: #dcfce7; color: #166534;"><i class="fas fa-check-circle me-1"></i>Đã duyệt</span>
            }
            else if (Model.ModerationStatus == "Rejected")
            {
                <span class="badge" style="background: #fee2e2; color: #991b1b;"><i class="fas fa-times-circle me-1"></i>Từ chối</span>
            }
            else
            {
                <span class="badge" style="background: #fef9c3; color: #854d0e;"><i class="fas fa-clock me-1"></i>Chờ duyệt</span>
            }
        </div>
    </div>
    
    <div class="emp-card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            
            <partial name="_JobForm" model="Model" />

            <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                <a class="emp-btn emp-btn-secondary text-danger" style="border-color:transparent; background:#fee2e2; color:#b91c1c;" asp-area="Employer" asp-controller="Jobs" asp-action="Delete" asp-route-id="@Model.Id" onclick="return confirm('Xóa tin tuyển dụng này?');">
                    <i class="fas fa-trash-alt me-2"></i>Xóa tin
                </a>
                <div class="d-flex gap-2">
                    <a class="emp-btn emp-btn-secondary" asp-area="Employer" asp-controller="Jobs" asp-action="Index">Hủy bỏ</a>
                    <button type="submit" class="emp-btn emp-btn-primary">
                        <i class="fas fa-save me-2"></i>Lưu thay đổi
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
