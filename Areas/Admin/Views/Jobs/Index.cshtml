@model List<JobPortal.Models.Entities.Job>

@{
    ViewData["Title"] = "Duyệt tin tuyển dụng";
    var status = (string)(ViewBag.Status ?? "Pending");
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-0">Quản lý tin tuyển dụng</h3>
        <div class="text-muted small">Lọc theo trạng thái: <strong>@status</strong></div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
        <a class="btn btn-outline-warning btn-sm" asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Pending">Pending</a>
        <a class="btn btn-outline-success btn-sm" asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Approved">Approved</a>
        <a class="btn btn-outline-danger btn-sm" asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Rejected">Rejected</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có tin nào với trạng thái này.</div>
}
else
{
    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Công ty</th>
                    <th>Ngành</th>
                    <th>Ngày đăng</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var j in Model)
                {
                    <tr>
                        <td class="fw-semibold">@j.Title</td>
                        <td>@j.Company?.CompanyName</td>
                        <td>@j.Category?.Name</td>
                        <td>@j.PostedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @switch (j.ModerationStatus)
                            {
                                case "Pending":
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case "Approved":
                                    <span class="badge bg-success">Approved</span>
                                    break;
                                case "Rejected":
                                    <span class="badge bg-danger">Rejected</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@j.ModerationStatus</span>
                                    break;
                            }
                        </td>
                        <td class="text-muted small">@j.ModerationNote</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Jobs" asp-action="Details" asp-route-id="@j.Id">Xem</a>

                            @if (j.ModerationStatus == "Pending")
                            {
                                <form method="post" class="d-inline" asp-area="Admin" asp-controller="Jobs" asp-action="Approve" asp-route-id="@j.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-success ms-1">Duyệt</button>
                                </form>

                                <button type="button" class="btn btn-sm btn-danger ms-1" data-bs-toggle="modal" data-bs-target="#rejectModal_@j.Id">Từ chối</button>
                            }

                            <form method="post" class="d-inline ms-1" asp-area="Admin" asp-controller="Jobs" asp-action="Delete" asp-route-id="@j.Id" onsubmit="return confirm('Xóa tin này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@foreach (var j in Model.Where(j => j.ModerationStatus == "Pending"))
{
    <div class="modal fade" id="rejectModal_@j.Id" tabindex="-1" aria-labelledby="rejectModalLabel_@j.Id" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="rejectModalLabel_@j.Id">Từ chối tin: @j.Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" asp-area="Admin" asp-controller="Jobs" asp-action="Reject" asp-route-id="@j.Id">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="note_@j.Id" class="form-label">Lý do từ chối (tùy chọn)</label>
                            <textarea class="form-control" id="note_@j.Id" name="note" rows="3" placeholder="Nhập lý do từ chối..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
