@model List<JobPortal.Models.Entities.ApplicationUser>

@{
    ViewData["Title"] = "Quản lý người dùng";
    var currentRole = (string)(ViewBag.Role ?? "All");
    var search = (string)(ViewBag.Search ?? "");
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalUsers = (int)ViewBag.TotalUsers;
}

@section Styles {
<style>
    .filter-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 20px; margin-bottom: 20px; }
    .user-table { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden; }
    .user-table table { margin-bottom: 0; }
    .user-table thead { background: #f8fafc; }
    .user-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .3px; color: #64748b; border-bottom: 1px solid #e2e8f0; padding: 12px 16px; }
    .user-table td { padding: 12px 16px; vertical-align: middle; font-size: 14px; border-bottom: 1px solid #f1f5f9; }
    .user-table tr:last-child td { border-bottom: none; }
    .user-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; color: #fff; flex-shrink: 0; }
    .user-info { display: flex; align-items: center; gap: 12px; }
    .user-info .name { font-weight: 600; color: #1e293b; }
    .user-info .email { font-size: 12px; color: #94a3b8; }
    .badge-role { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; }
    .badge-admin { background: #fef2f2; color: #dc2626; }
    .badge-employer { background: #eff6ff; color: #2563eb; }
    .badge-candidate { background: #f0fdf4; color: #16a34a; }
    .badge-banned { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .badge-active { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .action-btn { padding: 6px 14px; border-radius: 6px; border: 1px solid #e2e8f0; background: #fff; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; color: #475569; }
    .action-btn:hover { background: #f8fafc; }
    .action-btn.view { border-color: #cbd5e1; color: #475569; }
    .action-btn.view:hover { border-color: #94a3b8; color: #1e293b; background: #f1f5f9; }
    .action-btn.ban { border-color: #fbbf24; color: #b45309; }
    .action-btn.ban:hover { border-color: #d97706; color: #92400e; background: #fffbeb; }
    .action-btn.unban { border-color: #34d399; color: #059669; }
    .action-btn.unban:hover { border-color: #059669; color: #047857; background: #ecfdf5; }
    .action-btn.delete { border-color: #fca5a5; color: #dc2626; }
    .action-btn.delete:hover { border-color: #ef4444; color: #b91c1c; background: #fef2f2; }
    .stat-pill { display: inline-flex; align-items: center; gap: 6px; background: #f1f5f9; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; color: #475569; }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <span class="stat-pill"><i class="fas fa-users"></i> @totalUsers người dùng</span>
    </div>
</div>

<div class="filter-card">
    <form method="get" asp-area="Admin" asp-controller="Users" asp-action="Index" class="row g-2 align-items-end">
        <div class="col-md-3 col-6">
            <label class="form-label" style="font-size:12px;font-weight:600;color:#64748b;">VAI TRÒ</label>
            <select name="role" class="form-select form-select-sm" id="roleSelect">
                <option value="All">Tất cả</option>
                <option value="Admin">Admin</option>
                <option value="Employer">Employer</option>
                <option value="Candidate">Candidate</option>
            </select>
            <script>document.getElementById('roleSelect').value = '@currentRole';</script>
        </div>
        <div class="col-md-6 col-12">
            <label class="form-label" style="font-size:12px;font-weight:600;color:#64748b;">TÌM KIẾM</label>
            <input type="text" name="search" class="form-control form-control-sm" placeholder="Tên hoặc email..." value="@search" />
        </div>
        <div class="col-md-3 col-6">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-search me-1"></i>Lọc</button>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có người dùng nào.</div>
}
else
{
    <div class="user-table">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th style="text-align:right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var isBanned = u.LockoutEnd.HasValue && u.LockoutEnd > DateTimeOffset.UtcNow;
                        var avatarColor = u.Role switch { "Admin" => "#dc2626", "Employer" => "#2563eb", "Candidate" => "#16a34a", _ => "#64748b" };
                        var initial = string.IsNullOrEmpty(u.FullName) ? "?" : u.FullName[0].ToString().ToUpper();
                        <tr>
                            <td>
                                <div class="user-info">
                                    <div class="user-avatar" style="background:@avatarColor;">@initial</div>
                                    <div>
                                        <div class="name">@u.FullName</div>
                                        <div class="email">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge-role @(u.Role == "Admin" ? "badge-admin" : u.Role == "Employer" ? "badge-employer" : "badge-candidate")">
                                    @u.Role
                                </span>
                            </td>
                            <td>
                                @if (isBanned)
                                {
                                    <span class="badge-role badge-banned"><i class="fas fa-ban me-1"></i>Bị khóa</span>
                                }
                                else
                                {
                                    <span class="badge-role badge-active"><i class="fas fa-check me-1"></i>Hoạt động</span>
                                }
                            </td>
                            <td style="color:#64748b;font-size:13px;">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td style="text-align:right;">
                                <div class="d-flex gap-2 justify-content-end flex-wrap">
                                    <button class="action-btn view" onclick="openUserDetails(@u.Id)">
                                        <i class="fas fa-eye"></i>Xem
                                    </button>
                                    @if (u.Role != "Admin")
                                    {
                                        <form method="post" asp-area="Admin" asp-controller="Users" asp-action="Ban" asp-route-id="@u.Id" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            @if (isBanned)
                                            {
                                                <button type="submit" class="action-btn unban"><i class="fas fa-unlock"></i>Mở khóa</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="action-btn ban"><i class="fas fa-lock"></i>Khóa</button>
                                            }
                                        </form>
                                        <form method="post" asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@u.Id" id="deleteForm-@u.Id" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="action-btn delete" onclick="confirmDelete(@u.Id)">
                                                <i class="fas fa-trash"></i>Xóa
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index" asp-route-role="@currentRole" asp-route-search="@search" asp-route-page="@(currentPage - 1)">Trước</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index" asp-route-role="@currentRole" asp-route-search="@search" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Users" asp-action="Index" asp-route-role="@currentRole" asp-route-search="@search" asp-route-page="@(currentPage + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }
}

<!-- User Details Modal -->
<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header border-0 bg-light" style="border-radius: 12px 12px 0 0;">
                <h5 class="modal-title fw-bold text-dark" id="userDetailsModalLabel"><i class="fas fa-user-circle me-2 text-primary"></i>Chi tiết tài khoản</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" id="userDetailsContent">
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function openUserDetails(id) {
            const modal = new bootstrap.Modal(document.getElementById('userDetailsModal'));
            modal.show();
            
            document.getElementById('userDetailsContent').innerHTML = '<div class="text-center p-5"><div class="spinner-border text-primary" role="status"></div></div>';
            
            fetch(`/Admin/Users/DetailsPartial/${id}`)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.text();
                })
                .then(html => {
                    document.getElementById('userDetailsContent').innerHTML = html;
                })
                .catch(error => {
                    document.getElementById('userDetailsContent').innerHTML = '<div class="alert alert-danger m-3">Không thể tải thông tin chi tiết. Vui lòng thử lại.</div>';
                    console.error('Error fetching user details:', error);
                });
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'Xin xác nhận!',
                html: "Bạn có chắc chắn muốn xóa tài khoản này không? <br><small class='text-danger'>Thao tác này sẽ xóa toàn bộ dữ liệu liên quan trong database.</small>",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#64748b',
                confirmButtonText: '<i class="fas fa-trash me-1"></i> Xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteForm-' + id).submit();
                }
            })
        }
    </script>
}
