@model List<JobPortal.Models.Entities.Application>

@{
    ViewData["Title"] = "Quản lý đơn ứng tuyển";
    var currentStatus = (string)(ViewBag.Status ?? "All");
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalApplications = (int)ViewBag.TotalApplications;
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-0">Quản lý đơn ứng tuyển</h3>
        <div class="text-muted small">@totalApplications đơn</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" asp-area="Admin" asp-controller="Applications" asp-action="Index" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <!option value="All" @(currentStatus == "All" ? "selected" : "")>Tất cả</!option>
                    <!option value="Pending" @(currentStatus == "Pending" ? "selected" : "")>Pending</!option>
                    <!option value="Reviewing" @(currentStatus == "Reviewing" ? "selected" : "")>Reviewing</!option>
                    <!option value="Interview" @(currentStatus == "Interview" ? "selected" : "")>Interview</!option>
                    <!option value="Accepted" @(currentStatus == "Accepted" ? "selected" : "")>Accepted</!option>
                    <!option value="Rejected" @(currentStatus == "Rejected" ? "selected" : "")>Rejected</!option>
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-filter me-1"></i> Lọc</button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có đơn ứng tuyển nào.</div>
}
else
{
    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Công việc</th>
                    <th>Ứng viên</th>
                    <th>Email</th>
                    <th>Ngày ứng tuyển</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td class="fw-semibold">@a.Job?.Title</td>
                        <td>@a.User?.FullName</td>
                        <td>@a.User?.Email</td>
                        <td>@a.AppliedDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @switch (a.Status)
                            {
                                case "Pending":
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case "Reviewing":
                                    <span class="badge bg-info">Reviewing</span>
                                    break;
                                case "Interview":
                                    <span class="badge bg-primary">Interview</span>
                                    break;
                                case "Accepted":
                                    <span class="badge bg-success">Accepted</span>
                                    break;
                                case "Rejected":
                                    <span class="badge bg-danger">Rejected</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@a.Status</span>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Applications" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage - 1)">Trước</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-area="Admin" asp-controller="Applications" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-area="Admin" asp-controller="Applications" asp-action="Index" asp-route-status="@currentStatus" asp-route-page="@(currentPage + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }
}
