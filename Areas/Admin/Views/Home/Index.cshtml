@model JobPortal.Models.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
    var hasApplications = Model.TotalApplications > 0;
}

@section Styles {
    <style>
        .dashboard-panel { background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%); border: 1px solid #e2e8f0; border-radius: 20px; box-shadow: 0 16px 32px rgba(15, 23, 42, 0.06); }
        .dashboard-panel .card-body { padding: 1.5rem; }
        .dashboard-panel-title { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 0.25rem; }
        .dashboard-panel-subtitle { color: #64748b; font-size: 0.9rem; margin-bottom: 0; }
        .dashboard-chip { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.55rem 0.9rem; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: 0.85rem; font-weight: 600; }
        .chart-shell { position: relative; min-height: 300px; }
        .dashboard-stat-list { display: grid; gap: 0.85rem; margin-top: 1.25rem; }
        .dashboard-stat-item { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.95rem 1rem; border-radius: 16px; border: 1px solid #e2e8f0; background: #ffffff; }
        .dashboard-stat-main { display: flex; align-items: center; gap: 0.8rem; min-width: 0; }
        .dashboard-stat-icon { width: 42px; height: 42px; border-radius: 14px; display: inline-flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
        .dashboard-stat-name { font-weight: 600; color: #0f172a; margin-bottom: 0.1rem; }
        .dashboard-stat-meta { color: #64748b; font-size: 0.82rem; }
        .dashboard-stat-value { text-align: right; flex-shrink: 0; }
        .dashboard-stat-value strong { display: block; color: #0f172a; font-size: 1rem; }
        .dashboard-stat-value span { color: #64748b; font-size: 0.82rem; }

        .application-summary-strip { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.75rem; margin-bottom: 0.9rem; }
        .application-summary-card { border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; padding: 0.9rem 1rem; }
        .application-summary-label { color: #64748b; font-size: 0.8rem; margin-bottom: 0.2rem; }
        .application-summary-value { color: #0f172a; font-size: 1.45rem; font-weight: 700; line-height: 1.1; margin-bottom: 0.15rem; }
        .application-summary-meta { color: #475569; font-size: 0.8rem; margin-bottom: 0; }

        .application-main-grid { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.85fr); gap: 0.9rem; align-items: start; }
        .application-block { border: 1px solid #e2e8f0; border-radius: 18px; background: #fff; padding: 1rem; }
        .application-block-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.75rem; }
        .application-block-title { color: #0f172a; font-size: 0.95rem; font-weight: 700; margin-bottom: 0.1rem; }
        .application-block-subtitle { color: #64748b; font-size: 0.8rem; margin-bottom: 0; }
        .application-inline-chip { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.3rem 0.65rem; border-radius: 999px; background: #f8fafc; color: #475569; font-size: 0.76rem; font-weight: 600; white-space: nowrap; }
        .application-chart-shell { position: relative; min-height: 185px; }
        .application-chart-note { color: #64748b; font-size: 0.8rem; margin: 0.65rem 0 0; }

        .application-empty-state { min-height: 185px; border-radius: 16px; border: 1px dashed #cbd5e1; background: #f8fbff; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 1.25rem; }
        .application-empty-state .empty-icon { width: 46px; height: 46px; border-radius: 14px; background: #eff6ff; color: #2563eb; display: inline-flex; align-items: center; justify-content: center; font-size: 1.1rem; margin-bottom: 0.65rem; }
        .application-empty-state h6 { color: #0f172a; font-size: 0.96rem; font-weight: 700; margin-bottom: 0.25rem; }
        .application-empty-state p { color: #64748b; font-size: 0.82rem; margin: 0; max-width: 280px; }

        .application-status-list { display: grid; gap: 0.7rem; }
        .application-status-item { padding: 0.8rem 0.9rem; border-radius: 16px; border: 1px solid #e2e8f0; background: #fff; }
        .application-status-line { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 0.45rem; }
        .application-status-main { display: flex; align-items: center; gap: 0.65rem; min-width: 0; }
        .application-status-dot { width: 10px; height: 10px; border-radius: 999px; flex-shrink: 0; }
        .application-status-name { color: #0f172a; font-size: 0.9rem; font-weight: 600; }
        .application-status-count { color: #475569; font-size: 0.82rem; font-weight: 600; white-space: nowrap; }
        .application-status-bar { width: 100%; height: 8px; border-radius: 999px; overflow: hidden; background: #e2e8f0; }
        .application-status-bar span { display: block; height: 100%; border-radius: 999px; }
        .application-status-foot { display: flex; justify-content: space-between; gap: 1rem; color: #64748b; font-size: 0.76rem; margin-top: 0.35rem; }

        @@media (max-width: 1399.98px) { .application-summary-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
        @@media (max-width: 1199.98px) { .application-main-grid { grid-template-columns: 1fr; } }
        @@media (max-width: 767.98px) {
            .application-summary-strip { grid-template-columns: 1fr; }
            .dashboard-stat-item { align-items: flex-start; flex-direction: column; }
            .dashboard-stat-value { text-align: left; }
            .application-status-line { align-items: flex-start; flex-direction: column; }
        }
    </style>
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h2 class="mb-0">Dashboard Admin</h2>
        <div class="text-muted small">Tổng quan hệ thống</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary btn-sm" asp-area="Admin" asp-controller="Jobs" asp-action="Index">Duyệt tin</a>
        <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Categories" asp-action="Index">Danh mục</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Jobs" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon primary"><i class="fas fa-briefcase"></i></div>
                <div class="stat-card-value">@Model.TotalJobs</div>
                <div class="stat-card-label">Tổng tin tuyển dụng</div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Pending" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon warning"><i class="fas fa-hourglass-half"></i></div>
                <div class="stat-card-value">@Model.PendingJobs</div>
                <div class="stat-card-label">Chờ duyệt</div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon success"><i class="fas fa-users"></i></div>
                <div class="stat-card-value">@Model.TotalUsers</div>
                <div class="stat-card-label">Người dùng</div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Applications" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon danger"><i class="fas fa-file-alt"></i></div>
                <div class="stat-card-value">@Model.TotalApplications</div>
                <div class="stat-card-label">Đơn ứng tuyển</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon info"><i class="fas fa-tags"></i></div>
                <div class="stat-card-value">@Model.TotalCategories</div>
                <div class="stat-card-label">Danh mục</div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-card-icon primary"><i class="fas fa-building"></i></div>
            <div class="stat-card-value">@Model.TotalCompanies</div>
            <div class="stat-card-label">Công ty</div>
        </div>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Approved" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon success"><i class="fas fa-check-circle"></i></div>
                <div class="stat-card-value">@Model.ApprovedJobs</div>
                <div class="stat-card-label">Đã duyệt</div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-area="Admin" asp-controller="Jobs" asp-action="Index" asp-route-status="Rejected" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-card-icon danger"><i class="fas fa-times-circle"></i></div>
                <div class="stat-card-value">@Model.RejectedJobs</div>
                <div class="stat-card-label">Đã từ chối</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-4">
        <div class="card dashboard-panel h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h6 class="dashboard-panel-title">Trạng thái duyệt việc làm</h6>
                        <p class="dashboard-panel-subtitle">Hiển thị nhãn tiếng Việt và tỷ trọng thực tế của từng trạng thái.</p>
                    </div>
                    <div class="dashboard-chip">
                        <i class="fas fa-layer-group"></i>
                        @Model.TotalJobs tin
                    </div>
                </div>

                <div class="chart-shell d-flex justify-content-center align-items-center">
                    <canvas id="jobsByStatus"></canvas>
                </div>

                <div class="dashboard-stat-list">
                    @foreach (var item in Model.JobModerationStats)
                    {
                        <div class="dashboard-stat-item">
                            <div class="dashboard-stat-main">
                                <span class="dashboard-stat-icon" style="background:@item.SoftColor; color:@item.Color;">
                                    <i class="@item.IconClass"></i>
                                </span>
                                <div>
                                    <div class="dashboard-stat-name">@item.Label</div>
                                    <div class="dashboard-stat-meta">Trạng thái hiện tại của tin tuyển dụng</div>
                                </div>
                            </div>
                            <div class="dashboard-stat-value">
                                <strong>@item.Value</strong>
                                <span>@item.Percentage.ToString("0.#")%</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card dashboard-panel h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                    <div>
                        <h6 class="dashboard-panel-title">Thống kê đơn ứng tuyển</h6>
                        <p class="dashboard-panel-subtitle">Hiển thị gọn các chỉ số quan trọng nhất của hồ sơ ứng tuyển.</p>
                    </div>
                    <div class="dashboard-chip">
                        <i class="fas fa-chart-column"></i>
                        @Model.TotalApplications hồ sơ
                    </div>
                </div>

                <div class="application-summary-strip">
                    <div class="application-summary-card">
                        <div class="application-summary-label">Đang xử lý</div>
                        <div class="application-summary-value">@Model.PipelineApplications</div>
                        <p class="application-summary-meta">@Model.PipelinePercentage.ToString("0.#")% trong quy trình</p>
                    </div>
                    <div class="application-summary-card">
                        <div class="application-summary-label">Hoàn tất</div>
                        <div class="application-summary-value">@Model.CompletedApplications</div>
                        <p class="application-summary-meta">@Model.CompletionPercentage.ToString("0.#")% đã có kết quả</p>
                    </div>
                    <div class="application-summary-card">
                        <div class="application-summary-label">Tỷ lệ phỏng vấn</div>
                        <div class="application-summary-value">@Model.InterviewRate.ToString("0.#")%</div>
                        <p class="application-summary-meta">Từ tổng số hồ sơ</p>
                    </div>
                    <div class="application-summary-card">
                        <div class="application-summary-label">Tỷ lệ nhận</div>
                        <div class="application-summary-value">@Model.AcceptanceRate.ToString("0.#")%</div>
                        <p class="application-summary-meta">Từ tổng số hồ sơ</p>
                    </div>
                </div>

                <div class="application-main-grid">
                    <div class="application-block">
                        <div class="application-block-header">
                            <div>
                                <div class="application-block-title">Phân bổ trạng thái</div>
                                <p class="application-block-subtitle">Tổng quan nhanh theo từng trạng thái hồ sơ.</p>
                            </div>
                            <span class="application-inline-chip">
                                <i class="fas fa-layer-group"></i>
                                @Model.ApplicationStats.Count trạng thái
                            </span>
                        </div>

                        @if (hasApplications)
                        {
                            <div class="application-chart-shell">
                                <canvas id="applicationsByStatus"></canvas>
                            </div>
                            <p class="application-chart-note">Dựa trên trạng thái hiện tại của toàn bộ hồ sơ.</p>
                        }
                        else
                        {
                            <div class="application-empty-state">
                                <span class="empty-icon"><i class="fas fa-inbox"></i></span>
                                <h6>Chưa có đơn ứng tuyển</h6>
                                <p>Khi có hồ sơ mới, biểu đồ sẽ hiển thị ở đây theo dạng gọn và tập trung hơn.</p>
                            </div>
                        }
                    </div>

                    <div class="application-block">
                        <div class="application-block-header">
                            <div>
                                <div class="application-block-title">Tiến độ theo trạng thái</div>
                                <p class="application-block-subtitle">Giữ lại số lượng, phần trăm và thanh tiến độ.</p>
                            </div>
                        </div>

                        <div class="application-status-list">
                            @foreach (var item in Model.ApplicationStats)
                            {
                                <div class="application-status-item">
                                    <div class="application-status-line">
                                        <div class="application-status-main">
                                            <span class="application-status-dot" style="background:@item.Color;"></span>
                                            <span class="application-status-name">@item.Label</span>
                                        </div>
                                        <span class="application-status-count">@item.Value đơn · @item.Percentage.ToString("0.#")%</span>
                                    </div>
                                    <div class="application-status-bar">
                                        <span style="width:@item.Percentage.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)%; background:@item.Color;"></span>
                                    </div>
                                    <div class="application-status-foot">
                                        <span>@item.Value / @Model.TotalApplications đơn</span>
                                        <span>Tiến độ hiện tại</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const jobStats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.JobModerationStats.Select(item => new
        {
            label = item.Label,
            value = item.Value,
            color = item.Color,
            percentage = item.Percentage
        })));

        const appStats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ApplicationStats.Select(item => new
        {
            label = item.Label,
            value = item.Value,
            color = item.Color,
            percentage = item.Percentage
        })));

        const totalApplications = @Model.TotalApplications;
        const formatPercent = (value) => `${Number(value).toFixed(1).replace('.0', '')}%`;
        const dashboardFont = getComputedStyle(document.body).fontFamily || "'Segoe UI', sans-serif";

        const doughnutCenterText = {
            id: 'doughnutCenterText',
            afterDraw(chart, args, pluginOptions) {
                const { ctx, chartArea } = chart;
                if (!chartArea) return;

                const centerX = (chartArea.left + chartArea.right) / 2;
                const centerY = (chartArea.top + chartArea.bottom) / 2;

                ctx.save();
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillStyle = '#0f172a';
                ctx.font = `700 30px ${dashboardFont}`;
                ctx.fillText(pluginOptions.total, centerX, centerY - 8);
                ctx.fillStyle = '#64748b';
                ctx.font = `500 13px ${dashboardFont}`;
                ctx.fillText(pluginOptions.label, centerX, centerY + 18);
                ctx.restore();
            }
        };

        new Chart(document.getElementById('jobsByStatus'), {
            type: 'doughnut',
            data: {
                labels: jobStats.map(item => item.label),
                datasets: [{
                    data: jobStats.map(item => item.value),
                    backgroundColor: jobStats.map(item => item.color),
                    borderColor: '#ffffff',
                    borderWidth: 4,
                    hoverOffset: 6
                }]
            },
            plugins: [doughnutCenterText],
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '72%',
                layout: { padding: { top: 8, bottom: 8 } },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label(context) {
                                const item = jobStats[context.dataIndex];
                                return `${item.label}: ${item.value} tin (${formatPercent(item.percentage)})`;
                            }
                        }
                    },
                    doughnutCenterText: {
                        total: @Model.TotalJobs,
                        label: 'Tổng tin'
                    }
                }
            }
        });

        if (totalApplications > 0) {
            new Chart(document.getElementById('applicationsByStatus'), {
                type: 'bar',
                data: {
                    labels: appStats.map(item => item.label),
                    datasets: [{
                        label: 'Số lượng đơn',
                        data: appStats.map(item => item.value),
                        backgroundColor: appStats.map(item => item.color),
                        borderColor: appStats.map(item => item.color),
                        borderWidth: 1,
                        borderRadius: 999,
                        borderSkipped: false,
                        barThickness: 16,
                        maxBarThickness: 16
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    layout: { padding: { top: 4, right: 8, bottom: 4, left: 0 } },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f172a',
                            padding: 12,
                            displayColors: false,
                            callbacks: {
                                title(items) { return items[0]?.label ?? ''; },
                                label(context) {
                                    const item = appStats[context.dataIndex];
                                    return `${item.value} đơn (${formatPercent(item.percentage)})`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grace: '10%',
                            ticks: { stepSize: 1, color: '#64748b', precision: 0 },
                            grid: { color: '#e2e8f0', drawBorder: false },
                            border: { display: false }
                        },
                        y: {
                            ticks: {
                                color: '#334155',
                                font: { family: dashboardFont, size: 13, weight: '600' }
                            },
                            grid: { display: false },
                            border: { display: false }
                        }
                    }
                }
            });
        }
    </script>
}
