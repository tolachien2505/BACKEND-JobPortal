@model List<JobPortal.Models.Entities.Category>

@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h3 class="mb-0">Danh mục</h3>
        <div class="text-muted small">@Model.Count danh mục</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Home" asp-action="Index">Dashboard</a>
        <a class="btn btn-primary btn-sm" asp-area="Admin" asp-controller="Categories" asp-action="Create"><i class="fas fa-plus me-1"></i>Thêm danh mục</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có danh mục.</div>
}
else
{
    <div class="table-responsive shadow-sm border rounded">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Mô tả</th>
                    <th>ParentId</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td class="fw-semibold">@c.Name</td>
                        <td class="text-muted">@c.Description</td>
                        <td>@(c.ParentId?.ToString() ?? "-")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@c.Id">Sửa</a>
                            <form method="post" class="d-inline ms-1" asp-area="Admin" asp-controller="Categories" asp-action="Delete" asp-route-id="@c.Id" onsubmit="return confirm('Xóa danh mục này?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

