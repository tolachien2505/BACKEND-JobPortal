@model JobPortal.Models.Entities.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-end mb-3">
            <div>
                <h3 class="mb-0">Thêm danh mục</h3>
            </div>
            <a class="btn btn-outline-secondary btn-sm" asp-area="Admin" asp-controller="Categories" asp-action="Index">Quay lại</a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Tên</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ParentId (tuỳ chọn)</label>
                        <input asp-for="ParentId" class="form-control" type="number" />
                        <span asp-validation-for="ParentId" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Tạo</button>
                        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Categories" asp-action="Index">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

