@model JobPortal.Models.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Đăng nhập</h2>
                    
                    @if (ViewData.ModelState.ErrorCount > 0 && !ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0"><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</p>
                            }
                        </div>
                    }
                    
                    <form method="post" action="/Client/Account/Login" id="loginForm" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="Email">Email <span class="text-danger">*</span></label>
                            <div class="input-group input-group-with-icon">
                                <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                                <input type="email" id="Email" name="Email" class="form-control @(ViewData.ModelState["Email"]?.Errors?.Count > 0 ? "is-invalid" : "")"
                                       value="@Model?.Email" placeholder="name@email.com" required />
                            </div>
                            <div class="invalid-feedback @(ViewData.ModelState["Email"]?.Errors?.Count > 0 ? "d-block" : "d-none")" id="EmailError" role="alert">@(ViewData.ModelState["Email"]?.Errors?.FirstOrDefault()?.ErrorMessage ?? "Vui lòng nhập địa chỉ email.")</div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label" for="Password">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="input-group input-group-with-icon">
                                <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" id="Password" name="Password" class="form-control @(ViewData.ModelState["Password"]?.Errors?.Count > 0 ? "is-invalid" : "")"
                                       placeholder="Nhập mật khẩu của bạn" required />
                            </div>
                            <div class="invalid-feedback @(ViewData.ModelState["Password"]?.Errors?.Count > 0 ? "d-block" : "d-none")" id="PasswordError" role="alert">@(ViewData.ModelState["Password"]?.Errors?.FirstOrDefault()?.ErrorMessage ?? "Vui lòng nhập mật khẩu.")</div>
                        </div>
                        
                        <div class="mb-3 form-check">
                            <input type="checkbox" name="RememberMe" value="true" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
                    </form>
                    
                    <div class="text-center mt-3">
                        <p>Chưa có tài khoản? <a href="/Client/Account/Register">Đăng ký ngay</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var form = document.getElementById('loginForm');
            function showError(id, show) {
                var el = document.getElementById(id + 'Error');
                if (!el) return;
                if (show) { el.classList.remove('d-none'); el.classList.add('d-block'); }
                else { el.classList.add('d-none'); el.classList.remove('d-block'); }
            }
            form.addEventListener('submit', function(e) {
                var email = document.getElementById('Email');
                var password = document.getElementById('Password');
                email.classList.remove('is-invalid');
                password.classList.remove('is-invalid');
                showError('Email', false);
                showError('Password', false);
                var invalid = false;
                if (!email.value.trim()) { email.classList.add('is-invalid'); showError('Email', true); invalid = true; }
                if (!password.value.trim()) { password.classList.add('is-invalid'); showError('Password', true); invalid = true; }
                if (invalid) e.preventDefault();
            });
            ['Email', 'Password'].forEach(function(id) {
                var input = document.getElementById(id);
                if (input) input.addEventListener('input', function() {
                    input.classList.remove('is-invalid');
                    showError(id, false);
                });
            });
        })();
    </script>
}
