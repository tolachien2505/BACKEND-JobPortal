@model List<JobPortal.Models.Entities.UserCv>
@{
    ViewData["Title"] = "Quản lý CV";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h3 class="mb-1 fw-bold text-dark">Quản lý CV</h3>
            <p class="text-secondary mb-0">Tải lên các bản CV chuyên nghiệp để ứng tuyển dễ dàng hơn.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-light border d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="GuideCv">
                <i class="fa-solid fa-book-open me-2 text-secondary"></i>Hướng dẫn viết CV
            </a>
            <a class="btn btn-primary d-flex align-items-center" asp-area="Candidate" asp-controller="Cvs" asp-action="Upload">
                <i class="fa-solid fa-cloud-arrow-up me-2"></i>Tải CV Mới
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border border-light-subtle shadow-sm rounded-4 mt-4" style="min-height: 35vh;">
            <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
                <div class="mb-3 text-secondary" style="opacity: 0.5;">
                    <i class="fa-regular fa-file-pdf fa-4x"></i>
                </div>
                <h5 class="fw-semibold text-dark">Khung lưu trữ trống</h5>
                <p class="text-muted mb-4" style="max-width: 400px;">Bạn chưa tải lên CV nào. Tải lên một bản CV định dạng PDF để bắt đầu hành trình tìm việc.</p>
                <a class="btn btn-outline-primary px-4 rounded-pill" asp-area="Candidate" asp-controller="Cvs" asp-action="Upload">
                    Tải lên ngay
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4 mt-2">
            @foreach (var cv in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border border-light-subtle shadow-sm rounded-4 h-100 position-relative cv-card" style="transition: all 0.2s ease;">
                        @if (cv.IsDefault)
                        {
                            <span class="position-absolute top-0 end-0 badge bg-primary text-white mt-3 me-3 rounded-pill px-2 py-1 shadow-sm" style="font-size: 0.75rem; z-index: 2;">
                                <i class="fa-solid fa-star me-1 text-warning"></i>Mặc định
                            </span>
                        }
                        
                        <div class="card-body p-4 text-center mt-2 d-flex flex-column">
                            <div class="mb-3 text-danger mx-auto flex-shrink-0" style="width: 60px; height: 60px; background: #fff1f2; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-file-pdf fa-2x"></i>
                            </div>
                            
                            <h6 class="fw-bold mb-1 text-truncate text-dark px-2" title="@cv.FileName">@cv.FileName</h6>
                            <small class="text-secondary d-block mb-4">
                                <i class="fa-regular fa-clock me-1"></i> @cv.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </small>

                            <div class="d-flex gap-2 justify-content-center border-top pt-3 mt-auto">
                                <a href="@cv.StoredPath" target="_blank" rel="noopener" class="btn btn-sm btn-light border text-secondary flex-fill" title="Xem trước">
                                    <i class="fa-solid fa-eye"></i> Xem
                                </a>
                                
                                @if (!cv.IsDefault)
                                {
                                    <form method="post" asp-area="Candidate" asp-controller="Cvs" asp-action="SetDefault" class="flex-fill mb-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@cv.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary w-100" title="Đặt Mặc định">
                                            <i class="fa-solid fa-check"></i> Chọn
                                        </button>
                                    </form>
                                }
                                
                                <form method="post" asp-area="Candidate" asp-controller="Cvs" asp-action="Delete" class="mb-0" onsubmit="return confirm('Xác nhận xóa CV này vĩnh viễn?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@cv.Id" />
                                    <button type="submit" class="btn btn-sm btn-light border text-danger px-3 flex-shrink-0" title="Xóa CV">
                                        <i class="fa-regular fa-trash-can"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <style>
        .cv-card:hover { border-color: #dee2e6 !important; box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important; transform: translateY(-2px); }
    </style>
}
