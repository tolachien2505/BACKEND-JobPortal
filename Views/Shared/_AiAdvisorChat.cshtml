@* AI Career Advisor - Floating Chat *@

<form id="aiAntiForgeryForm" style="display:none">
    @Html.AntiForgeryToken()
</form>

<!-- Bubble -->
<div class="ai-bubble-wrapper" id="aiBubbleWrapper">
    <div class="ai-bubble-label" id="aiBubbleLabel">
        <span>Tư vấn & Hỗ trợ tìm việc làm</span>
        <button class="ai-bubble-label-close" id="aiBubbleLabelClose">&times;</button>
    </div>
    <button id="aiChatBubble" class="ai-chat-bubble">
        <svg class="ai-bubble-icon" viewBox="0 0 64 64" width="30" height="30" fill="none">
            <rect x="12" y="28" width="40" height="24" rx="4" fill="white" opacity="0.95"/>
            <rect x="22" y="20" width="20" height="10" rx="3" fill="none" stroke="white" stroke-width="2.5"/>
            <rect x="26" y="36" width="12" height="6" rx="2" fill="rgba(79,70,229,0.5)"/>
            <path d="M42 8 Q54 8 54 15 Q54 22 42 22 L37 22 L34 27 L34 22 Q24 22 24 15 Q24 8 34 8 Z" fill="white" opacity="0.9"/>
            <circle cx="33" cy="15" r="1.3" fill="rgba(79,70,229,0.8)"/>
            <circle cx="38" cy="15" r="1.3" fill="rgba(79,70,229,0.8)"/>
            <circle cx="43" cy="15" r="1.3" fill="rgba(79,70,229,0.8)"/>
        </svg>
    </button>
</div>

<!-- Chat Panel -->
<div id="aiChatPanel" class="ai-chat-panel">
    <!-- Header -->
    <div class="ai-chat-header">
        <div class="ai-chat-header-avatar">
            <svg viewBox="0 0 36 36" width="22" height="22" fill="none">
                <rect x="6" y="14" width="24" height="16" rx="3" fill="white" opacity="0.9"/>
                <rect x="12" y="9" width="12" height="7" rx="2" fill="none" stroke="white" stroke-width="2"/>
                <rect x="14" y="20" width="8" height="4" rx="1.5" fill="rgba(79,70,229,0.5)"/>
            </svg>
        </div>
        <div class="ai-chat-header-info">
            <h6>Tư vấn việc làm</h6>
            <small>Hỗ trợ tìm kiếm việc làm phù hợp</small>
        </div>
        <div class="ai-chat-header-actions">
            <button id="aiChatHistoryBtn" title="Lịch sử trò chuyện">
                <i class="fas fa-clock-rotate-left"></i>
            </button>
            <button id="aiChatNewBtn" title="Cuộc trò chuyện mới">
                <i class="fas fa-plus"></i>
            </button>
            <button id="aiChatCloseBtn" title="Đóng">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    <!-- History Panel (hidden by default) -->
    <div id="aiHistoryPanel" class="ai-history-panel">
        <div id="aiHistoryList" class="ai-history-empty">
            <i class="fas fa-clock-rotate-left" style="font-size:28px;display:block;margin-bottom:8px;color:#d1d5db;"></i>
            Chưa có lịch sử trò chuyện
        </div>
    </div>

    <!-- Messages -->
    <div id="aiChatMessages" class="ai-chat-messages">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="ai-welcome">
                <div class="ai-welcome-icon">
                    <svg viewBox="0 0 36 36" width="24" height="24" fill="none">
                        <rect x="6" y="14" width="24" height="16" rx="3" fill="white" opacity="0.95"/>
                        <rect x="12" y="9" width="12" height="7" rx="2" fill="none" stroke="white" stroke-width="2"/>
                        <rect x="14" y="20" width="8" height="4" rx="1.5" fill="rgba(255,255,255,0.5)"/>
                    </svg>
                </div>
                <h6>Xin chào!</h6>
                <p>Tôi sẽ giúp bạn tìm việc làm phù hợp.<br>Hãy cho tôi biết bạn đang tìm việc gì, hoặc tải CV lên để bắt đầu.</p>
            </div>
        }
        else
        {
            <div class="ai-login-required">
                <i class="fas fa-lock"></i>
                <p>Vui lòng đăng nhập để sử dụng<br>tính năng tư vấn việc làm</p>
                <a href="/Client/Account/Login" class="btn btn-primary">
                    <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                </a>
            </div>
        }
    </div>

    <!-- Input -->
    <div class="ai-chat-input-area">
        <div class="ai-chat-input-row">
            <div class="ai-upload-wrapper">
                <button id="aiChatUploadBtn" class="ai-chat-upload-btn" title="Tải CV lên">
                    <i class="fas fa-cloud-upload-alt"></i>
                </button>
                <span class="ai-upload-label">UP CV</span>
            </div>
            <input type="file" id="aiChatUploadInput" accept=".pdf,.docx" style="display:none" />
            <textarea id="aiChatInput" class="ai-chat-input" placeholder="Nhập tin nhắn..." rows="1"></textarea>
            <div class="ai-send-wrapper">
                <button id="aiChatSendBtn" class="ai-chat-send-btn" title="Gửi">
                    <i class="fas fa-paper-plane"></i>
                </button>
                <span class="ai-send-label">Gửi</span>
            </div>
        </div>
    </div>
</div>
